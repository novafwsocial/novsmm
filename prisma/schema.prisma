// NOVSMM — production schema
// SQLite-compatible: no native enums (use String), no Decimal (use Float),
// no Json (use String with JSON serialization), no arrays.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────── NextAuth required tables ───────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  username      String    @unique
  passwordHash  String?
  image         String?
  role          String    @default("user") // user | reseller | agency | admin
  country       String    @default("Mexico")
  currency      String    @default("USD")
  language      String    @default("English")
  status        String    @default("active") // active | suspended | pending
  balance       Float     @default(0)
  heldBalance   Float     @default(0)
  lifetimeEarnings Float  @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  transactions  Transaction[]
  notifications Notification[]
  tickets       Ticket[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────── Business models ───────────
model Provider {
  id        String   @id @default(cuid())
  name      String   @unique
  apiUrl    String
  apiKey    String?
  status    String   @default("healthy") // healthy | degraded | down
  latency   Int      @default(0)
  services  Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id           String   @id @default(cuid())
  name         String   @unique
  platform     String
  category     String   @default("general")
  description  String   @default("")
  quality      String   @default("standard") // standard | hq | premium | real
  deliveryTime String   @default("0-1h") // estimated delivery window
  cost         Float
  price        Float
  minQty       Int      @default(1)
  maxQty       Int      @default(100000)
  status       String   @default("active") // active | paused | deleted
  rate         String   @default("0/d")
  providerId   String?
  provider     Provider? @relation(fields: [providerId], references: [id])
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platform])
  @@index([status])
}

model Order {
  id              String   @id @default(cuid())
  publicId        String   @unique // A-10432 style
  userId          String
  serviceId       String?
  serviceName     String   // snapshot at order time
  platform        String   // snapshot
  quantity        Int
  unitCost        Float
  unitPrice       Float
  totalCost       Float
  totalPrice      Float
  profit          Float
  status          String   @default("processing") // pending | processing | in_progress | partial | completed | cancelled
  progress        Int      @default(0) // 0-100
  providerId      String?
  providerName    String?
  link            String?
  eta             String   @default("—")
  flag            String   @default("🌍")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@index([status])
}

model Transaction {
  id          String   @id @default(cuid())
  publicId    String   @unique // TX-8842 style
  userId      String
  type        String   // topup | withdrawal | sale | fee | referral | held | release
  amount      Float    // positive = credit, negative = debit
  description String
  status      String   @default("completed") // pending | completed | failed
  method      String?  // stripe | paypal | crypto | wise | manual
  reference   String?  // external txn id / payment intent
  orderId     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model PaymentMethod {
  id         String   @id @default(cuid())
  name       String   @unique
  glyph      String   @default("$")
  tone       String   @default("")
  settleTime String   @default("Instant")
  fee        String   @default("0%")
  currencies String   @default("USD")
  status     String   @default("active") // active | maintenance | disabled
  sortOrder  Int      @default(0)
  config     String?  // JSON: API keys, webhook secrets, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String   // order | sale | marketplace | ticket | recharge | withdrawal | referral | system
  title     String
  message   String
  amount    Float?
  severity  String   @default("info") // info | success | warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Ticket {
  id        String   @id @default(cuid())
  publicId  String   @unique // T-201 style
  userId    String
  subject   String
  status    String   @default("open") // open | waiting | resolved | closed
  priority  String   @default("medium") // low | medium | high
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  sender    String   // user | support
  text      String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // create | update | delete | login | logout | suspend
  entity    String   // user | service | provider | payment_method | order | etc.
  entityId  String?
  metadata  String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ─────────── API Keys (reseller integrations) ───────────
model ApiKey {
  id          String   @id @default(cuid())
  publicId    String   @unique // nvsk_... prefix
  keyHash     String   @unique // bcrypt hash of the full key (never store plaintext)
  name        String   // label e.g. "Production key"
  userId      String
  permissions String   @default("read,order") // comma-separated: read,order,wallet,marketplace
  status      String   @default("active") // active | revoked
  lastUsedAt  DateTime?
  lastUsedIp  String?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─────────── Licenses (panel rental / sale system) ───────────
model License {
  id            String   @id @default(cuid())
  licenseKey    String   @unique // encrypted, validated server-side
  licenseHash   String   @unique // bcrypt hash for lookup
  customerName  String
  customerEmail String
  customerId    String?  // linked user
  plan          String   @default("reseller") // reseller | agency | enterprise | white_label
  status        String   @default("active") // active | suspended | expired | revoked
  domain        String?  // allowed domain (for white-label)
  ipAllowlist   String?  // comma-separated allowed IPs
  maxUsers      Int      @default(1)
  maxOrders     Int      @default(10000)
  issuedAt      DateTime @default(now())
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([customerEmail])
}

// ─────────── Currencies (admin-managed) ───────────
model Currency {
  id        String  @id @default(cuid())
  code      String  @unique // USD, EUR, MXN...
  name      String
  symbol    String
  rate      Float   @default(1.0) // rate vs USD (for conversion)
  status    String  @default("active") // active | disabled
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────── Languages (admin-managed) ───────────
model Language {
  id        String  @id @default(cuid())
  code      String  @unique // en, es, pt, fr, de
  name      String
  nativeName String
  flag      String  @default("🌍")
  status    String  @default("active") // active | disabled
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────── Webhook logs (payment providers) ───────────
model WebhookLog {
  id        String   @id @default(cuid())
  provider  String   // stripe | mercadopago | paypal | aurora | manual
  eventType String   // payment.intent.succeeded, etc.
  payload   String   // raw JSON body
  signature String?
  status    String   @default("received") // received | processed | failed
  error     String?
  createdAt DateTime @default(now())

  @@index([provider])
  @@index([status])
}

// ─────────── Subscriptions (recurring billing) ───────────
model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  plan                 String   // starter | growth | enterprise
  stripeSubscriptionId String?
  status               String   @default("active") // active | canceled | past_due | trialing
  amount               Float    // monthly amount in USD
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ─────────── Invoices ───────────
model Invoice {
  id          String   @id @default(cuid())
  publicId    String   @unique // INV-0001
  userId      String
  type        String   // order | topup | subscription | refund
  amount      Float
  tax         Float    @default(0)
  total       Float
  currency    String   @default("USD")
  status      String   @default("paid") // paid | pending | void
  items       String   // JSON: [{ description, quantity, unitPrice, total }]
  pdfUrl      String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ─────────── Offers (marketplace sell) ───────────
model Offer {
  id         String   @id @default(cuid())
  userId     String
  serviceId  String
  price      Float    // reseller's price per 1000
  cost       Float    // original cost (for margin calc)
  margin     Float    // percentage margin
  status     String   @default("active") // active | paused | sold
  sales      Int      @default(0)
  earnings   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ─────────── Referrals ───────────
model Referral {
  id           String   @id @default(cuid())
  referrerId   String   // user who referred
  referredId   String?  // user who was referred (null until they sign up)
  referredEmail String  // email of the referred person
  code         String   @unique // unique referral code
  status       String   @default("pending") // pending | completed | rewarded
  earnings     Float    @default(0)
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([referrerId])
  @@index([code])
}

// ─────────── Coupons ───────────
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percent") // percent | fixed
  value       Float    // percentage (0-100) or fixed amount in USD
  maxUses     Int      @default(100)
  usedCount   Int      @default(0)
  status      String   @default("active") // active | disabled | expired
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([status])
}

// ─────────── Favorites ───────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
  @@index([userId])
}

// ─────────── Ticket attachments ───────────
model TicketAttachment {
  id        String   @id @default(cuid())
  messageId String
  filename  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  @@index([messageId])
}

// ─────────── Payment intents (real payment tracking) ───────────
model PaymentIntent {
  id              String   @id @default(cuid())
  publicId        String   @unique // pi_...
  userId          String
  amount          Float
  currency        String   @default("USD")
  method          String   // stripe | mercadopago | paypal | aurora | manual
  providerIntentId String? // stripe payment_intent_id, MP preference_id
  status          String   @default("pending") // pending | succeeded | failed | refunded
  description     String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerIntentId])
}
