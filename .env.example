# ─────────────────────────────────────────────────────────────
# NOVSMM — Environment Variables (Example)
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# Generate secret keys with: openssl rand -hex 32

# ── Database (PostgreSQL) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://novsmm:novsmm123@localhost:5432/novsmm?schema=public

# ── NextAuth.js ──
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
# Public URL of the app (no trailing slash). MUST be set in production so
# NextAuth doesn't derive the canonical URL from the (spoofable) Host header.
NEXTAUTH_URL=https://novsmm.shop
# SECURITY (OWASP A07-5, P3): DO NOT set AUTH_TRUST_HOST in production.
# When unset, NextAuth uses NEXTAUTH_URL as the canonical URL — which is
# safe because it's a server-side constant. Setting AUTH_TRUST_HOST=1 makes
# NextAuth trust the Host header on every request, which enables host-
# header-injection attacks (password-reset links pointing to attacker
# domains) if the Node port is ever exposed directly bypassing the proxy.
# The reverse proxy (Caddy/nginx) MUST always override the Host header.

# ── License Encryption (child panels) ──
# Generate with: openssl rand -hex 32 (64 hex chars, ≥128 bits entropy).
# SECURITY (OWASP A02-2, P2): must be ≥32 chars AND hex/base64 encoded.
# A weak passphrase like "password1234567" will be rejected at boot.
LICENSE_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ── HuntSMM Provider API ──
# API key for upstream SMM provider
HUNTSMM_API_KEY=replace-with-your-huntsmm-api-key

# ── Logging ──
LOG_LEVEL=info

# ── Environment ──
NODE_ENV=production

# ── Prometheus Metrics (OWASP A01-1) ──
# REQUIRED in production — /api/metrics returns 503 without it.
# Format: "username:password" (basic auth).
METRICS_BASIC_AUTH=metrics:replace-with-openssl-rand-hex-16

# ── Internal API token (backup-status endpoint) ──
# Required for /api/internal/backup-status — generate with openssl rand -hex 32
INTERNAL_API_TOKEN=replace-with-openssl-rand-hex-32
