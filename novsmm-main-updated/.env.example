# ─────────────────────────────────────────────────────────────
# NOVSMM — Environment Variables (Example)
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# Generate secret keys with: openssl rand -hex 32
#
# SECURITY FIX (C-001): all secrets are now EMPTY by default. The app
# will fail to boot if any required secret is missing — this is
# fail-closed behavior. Previously the placeholders like
# "replace-with-openssl-rand-hex-32" (32 chars) were silently accepted
# by NextAuth (which doesn't validate format), allowing anyone with
# repo access to forge admin JWTs.
#
# SECURITY FIX (C-002): added POSTGRES_PASSWORD and REDIS_PASSWORD
# that docker-compose.yml requires via ${VAR:?error} syntax.

# ── Database (PostgreSQL) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For local dev with SQLite: file:./db/custom.db
DATABASE_URL=postgresql://novsmm:CHANGE_ME@localhost:5432/novsmm?schema=public

# ── PostgreSQL (required by docker-compose.yml) ──
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=novsmm
POSTGRES_USER=novsmm

# ── Redis (required by docker-compose.yml) ──
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=

# ── NextAuth.js ──
# REQUIRED — generate with: openssl rand -hex 32
# Do NOT leave empty in production — the app will fail to boot.
NEXTAUTH_SECRET=
# Public URL of the app (no trailing slash). MUST be set in production so
# NextAuth doesn't derive the canonical URL from the (spoofable) Host header.
NEXTAUTH_URL=https://novsmm.shop
# SECURITY (OWASP A07-5, P3): DO NOT set AUTH_TRUST_HOST in production.
# When unset, NextAuth uses NEXTAUTH_URL as the canonical URL — which is
# safe because it's a server-side constant. Setting AUTH_TRUST_HOST=1 makes
# NextAuth trust the Host header on every request, which enables host-
# header-injection attacks (password-reset links pointing to attacker
# domains) if the Node port is ever exposed directly bypassing the proxy.
# The reverse proxy (Caddy/nginx) MUST always override the Host header.

# ── License Encryption (child panels) ──
# REQUIRED — generate with: openssl rand -hex 32 (64 hex chars, ≥128 bits entropy).
# SECURITY (OWASP A02-2, P2): must be ≥32 chars AND hex/base64 encoded.
# A weak passphrase like "password1234567" will be rejected at boot.
# The app validates format at startup — invalid values cause a hard crash.
LICENSE_ENCRYPTION_KEY=

# ── HuntSMM Provider API ──
# API key for upstream SMM provider
HUNTSMM_API_KEY=

# ── Logging ──
LOG_LEVEL=info

# ── Environment ──
NODE_ENV=production

# ── Prometheus Metrics (OWASP A01-1) ──
# REQUIRED in production — /api/metrics returns 503 without it.
# Format: "username:password" (basic auth).
METRICS_BASIC_AUTH=metrics:

# ── Internal API token (backup-status endpoint) ──
# REQUIRED — generate with openssl rand -hex 32
INTERNAL_API_TOKEN=

# ── Notifications Service (Socket.IO mini-service) ──
# Secret shared between the Next.js app and the notifications service
# for internal HTTP broadcast calls. Generate with: openssl rand -hex 32
NOTIFICATIONS_SERVICE_SECRET=

# ── Optional: OAuth Providers ──
# Uncomment and fill to enable social login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# ── Optional: Email (SMTP) ──
# Uncomment to enable email notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@novsmm.shop

# ── Optional: Public API CORS Allowlist ──
# Comma-separated list of origins allowed to call /api/v1/*
# Example: https://reseller1.com,https://reseller2.com
API_CORS_ALLOWLIST=
